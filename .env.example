APP_NAME="GPSManager"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8085
APP_TIMEZONE=Europe/Prague

APP_LOCALE=cs
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=cs_CZ

BCRYPT_ROUNDS=12
APP_MAINTENANCE_DRIVER=file

# ── Database (PostgreSQL doporučené pro JSON io_data + GIS výpočty) ──
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=gpsmanager
DB_USERNAME=gpsmanager
DB_PASSWORD=changeme-strong-password

# ── Cache / Session / Queue via Redis ──
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
QUEUE_CONNECTION=redis
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=info

# ── Mail (log = no real sending, replace with smtp / ses / mailgun for prod) ──
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── Microsoft 365 SSO (Azure AD) — VOLITELNÉ, vypnutí: nechejte prázdné ──
# Vytvoř App Registration na https://portal.azure.com → Azure Active Directory → App registrations
# Redirect URI: ${APP_URL}/auth/microsoft/callback
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=
MS_REDIRECT_URI=${APP_URL}/auth/microsoft/callback
# Domény povolené pro SSO (čárkou oddělené), prázdné = všechny
MS_ALLOWED_DOMAINS=

# ── Teltonika TCP Listener ──
# Port na kterém Laravel artisan command `gpsmanager:listen` poslouchá AVL packety.
# Doporučení: forward z router/firewall na tento port (typicky 5027 nebo 5028).
TELTONIKA_LISTEN_PORT=5027

# ── Nominatim reverse geocoding (OpenStreetMap) ──
# Default: nominatim.openstreetmap.org (free, 1 req/s limit, 30-day Redis cache).
# Pro produkční fleet (5+ vozidel) doporučujeme vlastní self-hosted Nominatim.
NOMINATIM_URL=https://nominatim.openstreetmap.org
NOMINATIM_USER_AGENT="GPSManager/0.1 (your-email@example.com)"

VITE_APP_NAME="${APP_NAME}"
